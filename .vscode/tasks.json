{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-ui",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/swgoh-command-bridge.UI/swgoh-command-bridge.UI.csproj",
        "--configuration",
        "Debug"
      ],
      "options": {
        "env": {
          "TEMP": "${workspaceFolder}/.tmp",
          "TMP": "${workspaceFolder}/.tmp"
        }
      },
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
