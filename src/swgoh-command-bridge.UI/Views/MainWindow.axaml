<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:swgoh_command_bridge.UI.ViewModels"
        xmlns:views="using:swgoh_command_bridge.UI.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="swgoh_command_bridge.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="swgoh-command-bridge">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:MainWindowViewModel}">
            <views:CharacterPrioritiesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ModThresholdsViewModel}">
            <views:ModThresholdsView/>
        </DataTemplate>
    </Window.DataTemplates>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="10">
            <Button Content="Home" Command="{Binding GoToHomeCommand}"/>
            <Button Content="Mod Thresholds" Command="{Binding GoToThresholdsCommand}"/>
        </StackPanel>

        <ContentControl Content="{Binding CurrentView}" Margin="10"/>
    </DockPanel>

</Window>
